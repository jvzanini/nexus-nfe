# ============================================================
# Nexus NFE — Template de variáveis de ambiente
# Copiar para .env.local (dev) ou usar como referência
# ============================================================

# === Core ===
DATABASE_URL=postgresql://user:password@localhost:5432/nexus_nfe
REDIS_URL=redis://localhost:6379
NEXTAUTH_SECRET=                    # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# === Email ===
RESEND_API_KEY=re_xxxxx

# === Admin Seed ===
ADMIN_EMAIL=admin@nexusai360.com
ADMIN_PASSWORD=

# === Encryption (módulo encryption) ===
ENCRYPTION_KEY=                     # openssl rand -hex 32

# === Deploy (produção) ===
DB_PASSWORD=
GHCR_TOKEN=
PORTAINER_URL=
PORTAINER_TOKEN=
